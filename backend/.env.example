NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/recruitkr
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace_with_a_64_plus_character_secret
JWT_REFRESH_SECRET=replace_with_a_64_plus_character_secret
